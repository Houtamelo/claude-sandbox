[Desktop Entry]
Type=Application
Name=Open in claude-sandbox
Icon=utilities-terminal
NoDisplay=true
Exec=true
MimeType=inode/directory;
X-KDE-ServiceTypes=KonqPopupMenu/Plugin
Actions=openInClaudeSandbox

[Desktop Action openInClaudeSandbox]
Name=Open in claude-sandbox
Icon=utilities-terminal
# %f is the right-clicked dir (or current dir for empty-space clicks).
# `; exec bash` keeps the terminal open after claude-sandbox exits so
# any error message (e.g. project-not-found hint) stays visible.
#
# {{BINARY}} is replaced at install time by `desktop::install_kde_servicemenu`
# with the absolute path to the running `claude-sandbox` binary
# (std::env::current_exe). KDE Plasma's systemd-user session doesn't put
# ~/.cargo/bin (or anywhere a user-installed binary might land) on PATH,
# and `bash -lc` doesn't reliably source the user's profile in the
# konsole-spawned-from-Plasma chain. An absolute path sidesteps the
# entire PATH question — works for cargo install, future package
# install, anything.
Exec=konsole --workdir %f -e bash -lc "{{BINARY}}; echo; exec bash"
